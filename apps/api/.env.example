# ============================================================
# VLP API 環境変数サンプル
# コピーして .env として使用してください: cp .env.example .env
# ============================================================

# ---- 必須 ----
DATABASE_URL=postgresql://user:password@localhost:5432/vlp
SECRET_KEY=your-secret-key-here

# ---- Sentry（任意） ----
SENTRY_DSN=

# ---- Stripe（任意・未設定時はモック動作） ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER_MONTHLY=price_...
STRIPE_PRICE_ID_STANDARD_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_STARTER_YEARLY=price_...
STRIPE_PRICE_ID_STANDARD_YEARLY=price_...
STRIPE_PRICE_ID_PRO_YEARLY=price_...

# ---- VAPID（Web Push通知・任意・未設定時は通知なし） ----
#
# VAPIDキーの生成方法:
#   pip install pywebpush
#   python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); print('PUBLIC:', v.public_key.public_bytes_raw().__repr__()); v.save_key('vapid_key.pem')"
#
# または web-push CLI を使う場合:
#   npm install -g web-push
#   web-push generate-vapid-keys
#
VAPID_PUBLIC_KEY=BExamplePublicKeyBase64UrlEncoded...
VAPID_PRIVATE_KEY=ExamplePrivateKeyBase64UrlEncoded...
VAPID_EMAIL=mailto:admin@example.com

# ---- LINE Messaging API（任意・未設定時はモック動作） ----
LINE_CHANNEL_ACCESS_TOKEN=xxx
LINE_CHANNEL_SECRET=xxx
# Webhook URL（LINE Developers Console に登録）:
#   https://<your-api-domain>/api/v1/line/webhook?store_id=<store_uuid>

# ---- CORS ----
FRONTEND_URL=https://vlp-web.onrender.com
